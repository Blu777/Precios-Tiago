// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ProductoMaestro {
  ean                  String           @id
  nombre_estandarizado String
  marca                String?
  contenido_neto       Float?
  unidad_medida        String?
  categoria_id         String?
  url_imagen           String?
  grupo_id             String?          // Añadido para clustering pre-calculado
  
  precios_sucursales   SucursalPrecio[]

  @@index([nombre_estandarizado])
  @@index([marca])
  @@index([grupo_id])
}

model SucursalPrecio {
  id                   Int             @id @default(autoincrement())
  producto_ean         String
  supermercado_id      String
  precio_actual        Float
  precio_lista         Float?
  promocion            String?
  disponible_online    Boolean         @default(true)
  url_imagen           String?
  product_url          String?
  ultima_actualizacion DateTime        @default(now())

  producto             ProductoMaestro @relation(fields: [producto_ean], references: [ean], onDelete: Cascade)

  @@unique([producto_ean, supermercado_id])
  @@index([producto_ean])
  @@index([disponible_online])
}

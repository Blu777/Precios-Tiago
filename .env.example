# Configuración de Entorno para MiraPrecios

# ---------------------------------------------------------
# Variables de Sistema (TrueNAS / Linux)
# ---------------------------------------------------------
# UID y GID del usuario propietario de los archivos (usualmente 1000 en Linux, u otro en TrueNAS)
PUID=1000
PGID=1000

# Zona Horaria (Para que el cron y los logs tengan la hora correcta)
TZ=America/Argentina/Buenos_Aires

# ---------------------------------------------------------
# Base de Datos (Local)
# ---------------------------------------------------------
# Ruta de la base de datos para Prisma (Frontend)
DATABASE_URL=file:///app/data/miraprecios.db

# ---------------------------------------------------------
# Base de Datos (Nube - Turso) [Opcional]
# ---------------------------------------------------------
# Si se desea exportar o sincronizar con una base de datos en Turso
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---------------------------------------------------------
# Notificaciones [Opcional]
# ---------------------------------------------------------
# Webhook de Discord para alertas del scraper
DISCORD_WEBHOOK_URL=
